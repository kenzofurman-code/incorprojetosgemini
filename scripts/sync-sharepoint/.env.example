# ─── Supabase (banco que é a fonte da verdade) ────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
# Use a SERVICE ROLE key aqui (não a anon key) — esse script roda no servidor
# (GitHub Action), nunca no navegador. Pegue em: Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=

# ─── Microsoft Graph / Azure AD App Registration ──────────────────────────
# Ver instruções completas em README.md deste diretório
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Use MS_SITE_ID se for sincronizar para um site do SharePoint
# (ex: biblioteca "Documentos" do site da Incor)
MS_SITE_ID=

# OU use MS_DRIVE_ID se preferir sincronizar direto para um drive específico
# (ex: um OneDrive de uma conta de serviço, ou outra biblioteca do SharePoint)
# Se ambos forem informados, MS_DRIVE_ID tem prioridade.
MS_DRIVE_ID=

# ─── Configuração da sincronização ────────────────────────────────────────
# UUID do projeto no Supabase que deve ser sincronizado
# (o seed "Blanc de Rouge" criado em supabase/schema.sql usa este id)
SYNC_PROJECT_ID=11111111-1111-1111-1111-111111111111

# Pasta raiz dentro do SharePoint/OneDrive onde tudo será organizado
SYNC_ROOT_FOLDER=IncorProjetos
